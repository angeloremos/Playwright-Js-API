# Use DEV , STG , PRD as values

environment = STG
region = KOREA

# Jira Integration Configuration
# Set to true to enable automatic Jira bug ticket creation on test failure
JIRA_ENABLED=false
# Your Jira server URL (e.g., https://jira.company.com)
JIRA_BASE_URL=
# Jira username or email for authentication
JIRA_EMAIL=
# Jira API token or password for authentication
JIRA_API_TOKEN=
# Jira project key (e.g., PROJ)
JIRA_PROJECT_KEY=
# Default assignee for bug tickets (leave empty for no assignee)
JIRA_DEFAULT_ASSIGNEE=
